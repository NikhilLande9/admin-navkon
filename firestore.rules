rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════
    // Helpers
    // ══════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    // The one hardcoded identity — always has full access.
    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == "nikhillande9@gmail.com";
    }

    // Admin status is stored as a boolean field `isAdmin` on the caller's
    // user document (keyed by lowercased email). This is completely
    // independent of the role label so roles can be renamed/deleted freely.
    function callerIsAdmin() {
      let emailKey = request.auth.token.email.lower();
      return isSuperAdmin() || (
        exists(/databases/$(database)/documents/users/$(emailKey)) &&
        get(/databases/$(database)/documents/users/$(emailKey)).data.isAdmin == true
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // Public website leads
    // ══════════════════════════════════════════════════════════════════════

    match /leads/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════
    // Users collection
    // Documents are keyed by lowercased email (e.g. "user@example.com").
    //
    // Read:   any signed-in user (needed for the Roles page to list users)
    // Update: user may update their own non-sensitive fields;
    //         any admin may update any field except isAdmin;
    //         only Super Admin may set/clear the isAdmin flag.
    // Create / Delete: Super Admin only.
    // ══════════════════════════════════════════════════════════════════════

    match /users/{userEmail} {
      allow read: if isSignedIn();

      // Self-update: cannot touch role, isAdmin, or email
      allow update: if isSignedIn()
        && request.auth.token.email.lower() == userEmail
        && !("role"    in request.resource.data.diff(resource.data).affectedKeys())
        && !("isAdmin" in request.resource.data.diff(resource.data).affectedKeys())
        && !("email"   in request.resource.data.diff(resource.data).affectedKeys());

      // Regular admin: can update anything except the isAdmin flag
      allow update: if callerIsAdmin()
        && !("isAdmin" in request.resource.data.diff(resource.data).affectedKeys());

      // Super Admin: can update absolutely anything, including isAdmin
      allow update: if isSuperAdmin();

      // Only Super Admin can create or hard-delete user documents
      allow create, delete: if isSuperAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // Role permissions config
    // Read:  any signed-in user (sidebar needs it to filter nav items)
    // Write: any admin (both Super Admin and regular admins can manage roles)
    // ══════════════════════════════════════════════════════════════════════

    match /config/rolePermissions {
      allow read:  if isSignedIn();
      allow write: if callerIsAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // Everything else in config
    // ══════════════════════════════════════════════════════════════════════

    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if callerIsAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // All other collections — signed-in users can read/write
    // (tighten per collection as needed)
    // ══════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
