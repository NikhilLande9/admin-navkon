rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email == "nikhillande9@gmail.com";
    }

    function getUserRole() {
      // Documents are keyed by lowercased email, not UID.
      // Guard against a missing user doc to avoid permission-denied crashes.
      let emailKey = request.auth.token.email.lower();
      return exists(/databases/$(database)/documents/users/$(emailKey))
        ? get(/databases/$(database)/documents/users/$(emailKey)).data.role
        : null;
    }

    // ── Public website leads ───────────────────────────────────────────────
    match /leads/{doc} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Users collection ───────────────────────────────────────────────────
    // Documents are keyed by lowercased email (e.g. "user@example.com").
    // Any signed-in user can read all user docs (needed for roles page).
    // Users can update their own non-sensitive fields.
    // Only the hardcoded admin can create/delete docs or change roles.
    match /users/{userEmail} {
      allow read: if isSignedIn();

      // Users can update their own doc but cannot touch role or email
      allow update: if isSignedIn()
        && request.auth.token.email.lower() == userEmail
        && !("role" in request.resource.data)
        && !("email" in request.resource.data);

      // Only admin can create/delete user docs or change roles
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // ── Role permissions config ────────────────────────────────────────────
    // Anyone signed in can read (needed to filter sidebar nav).
    // Only admin can write.
    match /config/rolePermissions {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Everything else in config ──────────────────────────────────────────
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── All other collections ──────────────────────────────────────────────
    // Signed-in users can read/write (adjust per collection as needed)
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
